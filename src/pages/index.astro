      </g>
    </svg>
    <h2 class="mt-4 text-4xl font-medium text-center">Codigo de vestimenta</h2>
    <span class="text-xl font-regular mt-4">Elegante Sport</span>
  </section>

  <section
    class="flex flex-col justify-center items-center mt-16 mb-32 relative"
  >
    <div class="text-center z-20">
      <span class="text-2xl font-medium">¡Confirma tu asistencia!</span>
      <p class="text-center text-xl mt-4 mb-12 px-6">
        Te estare esperando, porfavor confirma tu asistencia.
      </p>
      <a
        href="https://wa.me/1164378724"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-white hover:border-primary text-white bg-primary px-20 py-4 rounded-4xl text-lg font-medium hover:text-primary hover:bg-white transition-colors"
      >
        Confirmar asistencia
      </a>
    </div>
  </section>
  <section class="flex flex-col justify-center items-center mt-16 mb-32 px-4">
    <div class="mt-8 w-full flex justify-center items-center">
      <Image src={gift} alt="" class="size-30" />
    </div>
    <p class="text-lg text-center font-regular mt-4">
      ¡Lo más importante es que vengas a festejar conmigo! Si además querés
      hacerme un regalo, te dejo mi cuenta.
    </p>
    <div class="flex flex-col justify-center items-center mt-8">
      <span class="text-lg font-medium">Alias: mix.xv.milena</span>
      <span class="text-lg font-medium">CVU: 0000003100047206362936</span>
      <span class="text-lg font-medium">Nombre: Vanesa Paola Duarte</span>
    </div>
  </section>
  <footer
    class="bg-primary text-white flex flex-col justify-center items-center mt-8 px-4 py-12 text-center"
  >
    <p>¡Espero que puedas venir y compartir este momento conmigo!</p>
  </footer>
</Layout>

<script>
  document.getElementById("boton")?.addEventListener("click", (e) => {
    e.preventDefault();

    document.getElementById("section")?.scrollIntoView({
      behavior: "smooth",
    });
  });
</script>

<style>
  .bar {
    position: relative;
  }

  .bar::after {
    content: "";
    position: absolute;
    bottom: -0.6rem;
    left: 50%;
    transform: translate(-50%, 0%);
    width: 50%;
    height: 0.2rem;
    border-radius: 0.2rem;
    background-color: var(--color-primary);
  }
</style>
